{
  "$defs": {
    "ContactInfo": {
      "additionalProperties": false,
      "description": "Contact information for the submission.",
      "properties": {
        "email": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Contact email for questions about this submission",
          "title": "Email"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Name of the submitter",
          "title": "Name"
        },
        "github": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "GitHub username (optional)",
          "title": "Github"
        }
      },
      "title": "ContactInfo",
      "type": "object"
    },
    "DomainResults": {
      "additionalProperties": false,
      "description": "Results for a specific domain.",
      "properties": {
        "pass_1": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Pass^1 success rate percentage",
          "title": "Pass 1"
        },
        "pass_2": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Pass^2 success rate percentage",
          "title": "Pass 2"
        },
        "pass_3": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Pass^3 success rate percentage",
          "title": "Pass 3"
        },
        "pass_4": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Pass^4 success rate percentage",
          "title": "Pass 4"
        },
        "cost": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Average cost in USD to run one trajectory in this domain (optional)",
          "title": "Cost"
        },
        "retrieval_config": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Retrieval method used for knowledge base access (banking_knowledge domain only)",
          "title": "Retrieval Config"
        }
      },
      "title": "DomainResults",
      "type": "object"
    },
    "Methodology": {
      "additionalProperties": false,
      "description": "Information about how the evaluation was conducted.",
      "properties": {
        "evaluation_date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Date when evaluation was conducted",
          "title": "Evaluation Date"
        },
        "tau2_bench_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Version of tau-bench used for evaluation",
          "title": "Tau2 Bench Version"
        },
        "user_simulator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "For text: model name (e.g. 'gpt-4.1-2025-04-14'). For voice: version identifier (e.g. 'v1.0') anchored to git tag voice-user-sim-<version>.",
          "title": "User Simulator"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Additional notes about the evaluation methodology",
          "title": "Notes"
        },
        "verification": {
          "anyOf": [
            {
              "$ref": "#/$defs/Verification"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Verification details for result authenticity"
        }
      },
      "title": "Methodology",
      "type": "object"
    },
    "ModelRelease": {
      "additionalProperties": false,
      "description": "Information about when and where the model was publicly released.\n\nThis metadata is about the model itself (independent of when it was\nevaluated on tau2-bench), and is used to track model progress over time\non the leaderboard.",
      "properties": {
        "release_date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Public release date of the model (YYYY-MM-DD). Use the date the model was first made publicly available, not the evaluation date.",
          "title": "Release Date"
        },
        "announcement_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "URL to the model's release announcement (blog post, paper, model card, release notes, etc.).",
          "title": "Announcement Url"
        },
        "announcement_title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Title of the release announcement (used as link text in the UI).",
          "title": "Announcement Title"
        }
      },
      "title": "ModelRelease",
      "type": "object"
    },
    "Reference": {
      "additionalProperties": false,
      "description": "A reference link (paper, blog post, github repo, etc.).",
      "properties": {
        "title": {
          "description": "Title or description of the reference",
          "title": "Title",
          "type": "string"
        },
        "url": {
          "description": "URL to the reference",
          "title": "Url",
          "type": "string"
        },
        "type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Type of reference: paper, blog_post, documentation, model_card, github, huggingface, other",
          "title": "Type"
        }
      },
      "required": [
        "title",
        "url"
      ],
      "title": "Reference",
      "type": "object"
    },
    "Results": {
      "additionalProperties": false,
      "description": "Performance results for each domain.",
      "properties": {
        "retail": {
          "anyOf": [
            {
              "$ref": "#/$defs/DomainResults"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "airline": {
          "anyOf": [
            {
              "$ref": "#/$defs/DomainResults"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "telecom": {
          "anyOf": [
            {
              "$ref": "#/$defs/DomainResults"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "banking_knowledge": {
          "anyOf": [
            {
              "$ref": "#/$defs/DomainResults"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "Results",
      "type": "object"
    },
    "Verification": {
      "additionalProperties": false,
      "description": "Verification details for result authenticity.",
      "properties": {
        "modified_prompts": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether any modifications were made to user simulator or agent prompts",
          "title": "Modified Prompts"
        },
        "omitted_questions": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether any questions/tasks were omitted from the evaluation",
          "title": "Omitted Questions"
        },
        "details": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Additional verification details or explanations",
          "title": "Details"
        }
      },
      "title": "Verification",
      "type": "object"
    },
    "VoiceConfig": {
      "additionalProperties": false,
      "description": "Voice-specific configuration for reproducing audio-native evaluations.",
      "properties": {
        "provider": {
          "description": "Audio-native provider (e.g. 'openai', 'gemini', 'xai')",
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "description": "Audio-native model identifier (e.g. 'gpt-realtime-1.5')",
          "title": "Model",
          "type": "string"
        },
        "tick_duration_seconds": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Duration of each simulation tick in seconds",
          "title": "Tick Duration Seconds"
        },
        "max_steps_seconds": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Maximum simulation duration in seconds",
          "title": "Max Steps Seconds"
        },
        "user_tts_provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "User simulator TTS provider and model (e.g. 'elevenlabs/eleven_v3')",
          "title": "User Tts Provider"
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "title": "VoiceConfig",
      "type": "object"
    }
  },
  "description": "Schema for submitting model results to the tau2-bench leaderboard. Auto-generated from the Pydantic model in src/tau2/scripts/leaderboard/submission.py \u2014 do not edit by hand.",
  "examples": [
    {
      "contact_info": {
        "email": "researcher@openai.com",
        "github": "janedoe",
        "name": "Jane Doe"
      },
      "is_new": true,
      "methodology": {
        "evaluation_date": "2024-01-10",
        "notes": "Evaluated using default configuration with 4 trials per task",
        "tau2_bench_version": "1.0.0",
        "user_simulator": "gpt-4.1",
        "verification": {
          "details": "Standard evaluation with unmodified prompts",
          "modified_prompts": false,
          "omitted_questions": false
        }
      },
      "model_name": "GPT-4.1",
      "model_organization": "OpenAI",
      "model_release": {
        "announcement_title": "Introducing GPT-4.1",
        "announcement_url": "https://openai.com/index/gpt-4-1/",
        "release_date": "2024-01-10"
      },
      "results": {
        "airline": {
          "pass_1": 78.9,
          "pass_2": 89.4,
          "pass_3": 94.7,
          "pass_4": 97.1
        },
        "retail": {
          "pass_1": 85.5,
          "pass_2": 92.3,
          "pass_3": 96.1,
          "pass_4": 98.2
        },
        "telecom": {
          "cost": 10.0,
          "pass_1": 82.1,
          "pass_2": 90.8,
          "pass_3": 95.3,
          "pass_4": 98.5
        }
      },
      "submission_date": "2024-01-15",
      "submission_type": "standard",
      "submitting_organization": "OpenAI",
      "trajectories_available": true,
      "trajectory_files": {
        "airline": "gpt-4.1_airline_default_gpt-4o_4trials.json",
        "retail": "gpt-4.1_retail_default_gpt-4o_4trials.json",
        "telecom": "gpt-4.1_telecom_default_gpt-4o_4trials.json"
      }
    }
  ],
  "properties": {
    "model_name": {
      "description": "Name of the model being evaluated",
      "title": "Model Name",
      "type": "string"
    },
    "model_organization": {
      "description": "Organization or company that developed the model",
      "title": "Model Organization",
      "type": "string"
    },
    "submitting_organization": {
      "description": "Organization that actually ran the evaluation and submitted the results",
      "title": "Submitting Organization",
      "type": "string"
    },
    "submission_date": {
      "description": "Date of submission",
      "format": "date",
      "title": "Submission Date",
      "type": "string"
    },
    "submission_type": {
      "default": "standard",
      "description": "Type of submission: 'standard' uses the default tau2-bench scaffold, 'custom' uses modified scaffolds (multi-model routers, additional tools, custom prompting, etc.)",
      "enum": [
        "standard",
        "custom"
      ],
      "title": "Submission Type",
      "type": "string"
    },
    "modality": {
      "default": "text",
      "description": "Evaluation modality: 'text' for standard text-based, 'voice' for audio-native",
      "enum": [
        "text",
        "voice"
      ],
      "title": "Modality",
      "type": "string"
    },
    "contact_info": {
      "$ref": "#/$defs/ContactInfo",
      "description": "Contact information"
    },
    "results": {
      "$ref": "#/$defs/Results",
      "description": "Performance results for each domain"
    },
    "is_new": {
      "default": false,
      "description": "Whether this model should be highlighted as new on the leaderboard",
      "title": "Is New",
      "type": "boolean"
    },
    "trajectories_available": {
      "default": false,
      "description": "Whether trajectory files are available for this submission",
      "title": "Trajectories Available",
      "type": "boolean"
    },
    "trajectory_files": {
      "anyOf": [
        {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Mapping of domain name to trajectory filename (e.g. {'retail': 'my-model_retail_...json'})",
      "title": "Trajectory Files"
    },
    "references": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/Reference"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Links to papers, blog posts, documentation, or other resources",
      "title": "References"
    },
    "methodology": {
      "anyOf": [
        {
          "$ref": "#/$defs/Methodology"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Information about how the evaluation was conducted"
    },
    "voice_config": {
      "anyOf": [
        {
          "$ref": "#/$defs/VoiceConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Voice-specific configuration for audio-native evaluations (only for voice submissions)"
    },
    "model_release": {
      "anyOf": [
        {
          "$ref": "#/$defs/ModelRelease"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Public release metadata for the model itself (release date and announcement link). Distinct from `submission_date`, which is when the evaluation was submitted. Used to track model progress over time."
    },
    "reasoning_effort": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reasoning/thinking effort level used during evaluation (e.g. 'high', 'low', 'none', 'enabled')",
      "title": "Reasoning Effort"
    }
  },
  "required": [
    "model_name",
    "model_organization",
    "submitting_organization",
    "submission_date",
    "contact_info",
    "results"
  ],
  "title": "Tau2-Bench Leaderboard Submission",
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
